# 复制为 .env 后按需修改（docker compose 可引用，或直接在 compose 中配置）

# PostgreSQL（与 docker-compose.yml 中 postgres 服务保持一致）
POSTGRES_USER=quickbuild
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=quickbuild

# 后端
DATABASE_URL=postgresql+psycopg://quickbuild:change-me-strong-password@postgres:5432/quickbuild
REDIS_URL=redis://redis:6379/0

# 生产环境必改：用于加密 SSH 密码等敏感数据
APP_SECRET=change-me-use-openssl-rand-hex-32

# 允许访问 API 的前端来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://deploy.example.com

# 任务数据保留时长（小时）
TASK_EXPIRE_HOURS=24

# 每小时部署次数限制
RATE_LIMIT_PER_HOUR=5
